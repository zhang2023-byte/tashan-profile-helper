# 当前使用的 AI 提供商：zhipuai | kimi | qwen | deepseek | minimax
LLM_PROVIDER=zhipuai

# 可选：覆盖默认模型，如 glm-4.7、moonshot-v1、qwen-plus、deepseek-chat 等
# LLM_MODEL=glm-4.7

# === 各提供商 API Key（按需配置，只需配置当前 LLM_PROVIDER 对应的 Key）===

# 智谱 AI (GLM)
ZHIPUAI_API_KEY=

# Kimi / Moonshot
KIMI_API_KEY=

# 通义千问 (Qwen) / DashScope
QWEN_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# MiniMax（暂需单独适配）
MINIMAX_API_KEY=
